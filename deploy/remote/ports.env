# ============================================================
# NovelBridge — 远程服务端口集中配置
# 所有服务端口在此文件定义，脚本通过 source 读取
# 修改后需重启相关服务
# ============================================================

# ---- llama-server (OpenAI-compatible) ----
# 绑定 127.0.0.1，不暴露到局域网
LLAMA_PORT=18080
LLAMA_HOST=127.0.0.1

# ---- rag-agent (Python FastAPI) ----
# 绑定 0.0.0.0，Spring Boot 可调用
RAG_AGENT_PORT=18081
RAG_AGENT_HOST=0.0.0.0

# ---- MySQL (Docker) ----
# 映射到 13306 避免与系统 MySQL 冲突
MYSQL_PORT=13306
MYSQL_HOST=127.0.0.1
MYSQL_DATABASE=novel_bridge

# ---- Neo4j ----
NEO4J_HTTP_PORT=17474
NEO4J_BOLT_PORT=17687
NEO4J_HOST=127.0.0.1

# ---- Vector DB (Qdrant / Chroma) ----
VECTOR_DB_PORT=16333
VECTOR_DB_HOST=127.0.0.1

# ---- llama.cpp GPU 配置 ----
# -ngl 层数（默认 99 = 全部上 GPU，0 = CPU only）
LLAMA_NGL=99
# 双卡切分模式：layer / row / none（空 = 单卡）
# layer: 按层切分（流水线），适合 MoE 模型
# row: 按行切分（并行），需要显存足够放全部参数
# 当前为 layer 模式（2*24GB=48GB > 35GB 模型）
LLAMA_SPLIT_MODE=layer

# ---- Search / BM25 (预留，Demo 6+) ----
SEARCH_PORT=18083
SEARCH_HOST=127.0.0.1
