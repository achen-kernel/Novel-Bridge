# ===== NovelBridge Remote Environment =====
# 复制为 .env 后填写真实值

# MySQL
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=novel_bridge
MYSQL_USER=novel_bridge
MYSQL_PASSWORD=change_me
MYSQL_DATA_DIR=/home/wk/novelbridge/data/mysql

# Neo4j
NEO4J_AUTH=neo4j/change_me_too
NEO4J_DATA_DIR=/home/wk/novelbridge/data/neo4j

# Qdrant
QDRANT_PORT=16333
QDRANT_DATA_DIR=/home/wk/novelbridge/data/qdrant

# llama-server
LLAMA_BIN=/home/wk/novelbridge/apps/llama.cpp/build/bin/llama-server
LLAMA_MODEL_PATH=/home/wk/novelbridge/models/qwen3.6-35b-gguf/Qwen_Qwen3.6-35B-A3B-Q8_0.gguf

# rag-agent
RAG_AGENT_DIR=/home/wk/novelbridge/apps/rag-agent
RAG_AGENT_VENV=/home/wk/novelbridge/env/rag-agent

# Paths
NB_REMOTE_DEPLOY_DIR=/home/wk/novelbridge
LOG_DIR=/home/wk/novelbridge/logs
