# ============================================================
# NovelBridge — 远程部署环境变量模板
# 复制为 .env 并填入真实值后再运行 nb_up.sh
# 重要：不要将 .env 提交到仓库！
# ============================================================

# ---- 远程服务器连接（可安全提交到仓库） ----
NB_REMOTE_HOST=192.168.3.50
NB_REMOTE_PORT=22
NB_REMOTE_USER=wk

# ---- 项目根目录（必须与服务器实际结构一致） ----
NB_REMOTE_DEPLOY_DIR=/home/wk/novelbridge

# ---- 应用路径 ----
RAG_AGENT_DIR=/home/wk/novelbridge/apps/rag-agent
LLAMA_BIN=/home/wk/novelbridge/apps/llama.cpp/llama-server

# ---- 模型路径 ----
LLAMA_MODEL_PATH=/home/wk/novelbridge/models/qwen3.6-35b-gguf/qwen3.6-35b-q4_k_m.gguf

# ---- 日志（按服务分目录） ----
LOG_DIR=/home/wk/novelbridge/logs

# ---- MySQL（Docker 挂载） ----
MYSQL_ROOT_PASSWORD=YOUR_MYSQL_PASSWORD_HERE
MYSQL_DATA_DIR=/home/wk/novelbridge/data/mysql

# ---- Neo4j（Docker 挂载） ----
NEO4J_AUTH=neo4j/YOUR_NEO4J_PASSWORD_HERE
NEO4J_DATA_DIR=/home/wk/novelbridge/data/neo4j

# ---- Chroma（rag-agent 内嵌，持久化路径） ----
CHROMA_DATA_DIR=/home/wk/novelbridge/data/chroma

# ---- rag-agent Python 虚拟环境 ----
RAG_AGENT_VENV=/home/wk/novelbridge/apps/rag-agent/.venv
