# NovelBridge chunk extraction output grammar
# Forces the model to output valid JSON with entity_mentions, relation_mentions, event_mentions
# Supports empty arrays (e.g., {"entity_mentions":[], "relation_mentions":[], "event_mentions":[...]})
root           ::= object
object         ::= "{" ws chapter_summary "," ws entity_mentions "," ws relation_mentions "," ws event_mentions ws "}"
chapter_summary ::= "\"chapter_summary\"" ws ":" ws string
entity_mentions ::= "\"entity_mentions\"" ws ":" ws "[" ws entity_array ws "]"
relation_mentions ::= "\"relation_mentions\"" ws ":" ws "[" ws relation_array ws "]"
event_mentions ::= "\"event_mentions\"" ws ":" ws "[" ws event_array ws "]"

entity_array  ::= entity ("," ws entity)*
entity        ::= "{" ws entity_fields ws "}"
entity_fields ::= surface_text "," ws normalized_name "," ws entity_type "," ws mention_role "," ws evidence_text "," ws confidence ("," ws description_field)?
surface_text  ::= "\"surface_text\"" ws ":" ws string
normalized_name ::= "\"normalized_name\"" ws ":" ws string
entity_type  ::= "\"entity_type\"" ws ":" ws string
mention_role ::= "\"mention_role\"" ws ":" ws string
evidence_text ::= "\"evidence_text\"" ws ":" ws string
confidence   ::= "\"confidence\"" ws ":" ws number
description_field ::= "\"description\"" ws ":" ws string

relation_array ::= relation ("," ws relation)*
relation     ::= "{" ws relation_fields ws "}"
relation_fields ::= source "," ws target "," ws relation_type "," ws evidence_text "," ws confidence
source       ::= "\"source\"" ws ":" ws string
target       ::= "\"target\"" ws ":" ws string
relation_type ::= "\"relation_type\"" ws ":" ws string

event_array   ::= event ("," ws event)*
event        ::= "{" ws event_fields ws "}"
event_fields ::= event_type "," ws description "," ws participants "," ws location "," ws evidence_text "," ws confidence
event_type   ::= "\"event_type\"" ws ":" ws string
description  ::= "\"description\"" ws ":" ws string
participants ::= "\"participants\"" ws ":" ws array
location     ::= "\"location\"" ws ":" ws string

array        ::= "[" ws "]" | "[" ws string_list ws "]"
string_list  ::= string ("," ws string)*

string       ::= "\"" char* "\""
char         ::= [^"\\] | "\\" escape
escape       ::= [\\"\/bfnrt] | "u" [0-9a-fA-F] [0-9a-fA-F] [0-9a-fA-F] [0-9a-fA-F]
number       ::= [0-9] "." [0-9] ([eE] [+\-]? [0-9]+)?
ws           ::= [ \t\n\r]*
